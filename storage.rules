rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function userRole() {
      return firestore.get(userDocPath()).data.role;
    }

    function isAdminOrSeller() {
      return isSignedIn() && (userRole() == 'admin' || userRole() == 'seller');
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOrSeller();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
